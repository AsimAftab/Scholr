# ==============================================================================
# SCHOLR PRODUCTION ENVIRONMENT TEMPLATE
# ==============================================================================
# IMPORTANT: DO NOT COMMIT REAL KEYS TO VERSION CONTROL.
# Copy this file to .env and fill in the actual production values.
# ==============================================================================

# Database
# Use a managed PostgreSQL service (e.g., RDS, GCP Cloud SQL)
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DB_NAME

# AI provider selection (options: openai, cerebras, glm, ollama, local)
# In production, recommend using redundant providers in AI_FALLBACK_ORDER
AI_PROVIDER=openai
AI_FALLBACK_ORDER=cerebras,glm

# OpenAI config
OPENAI_API_KEY=YOUR_PRODUCTION_KEY
OPENAI_MODEL=gpt-4o

# Cerebras config
CEREBRAS_API_KEY=YOUR_PRODUCTION_KEY
CEREBRAS_MODEL=llama3.1-70b
CEREBRAS_MAX_COMPLETION_TOKENS=4096

# GLM config
GLM_API_KEY=YOUR_PRODUCTION_KEY
GLM_MODEL=glm-4
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# Matching algorithm config
LLM_MATCH_TOP_N=20
LLM_MATCH_RULE_WEIGHT=0.5

# Tinyfish config (Crawler support)
TINYFISH_API_KEY=YOUR_PRODUCTION_KEY
TINYFISH_BASE_URL=https://agent.tinyfish.ai
TINYFISH_TIMEOUT_SECONDS=300

# Frontend / session
# CORS_ORIGINS must be the actual domain of your frontend (no trailing slash)
CORS_ORIGINS=https://scholr.ai
# SESSION_SECRET must be a long, random string (e.g., 64+ characters)
SESSION_SECRET=GENERATE_A_RANDOM_SECURE_SECRET
SESSION_COOKIE_NAME=scholr_session_prod
SESSION_COOKIE_SECURE=true

# Security & Operations
AUTO_SEED=false
ADMIN_EMAIL=admin@YOUR_DOMAIN.COM
ADMIN_PASSWORD=SET_A_SECURE_ADMIN_PASSWORD
ADMIN_FULL_NAME=Scholr Administrator
LOG_LEVEL=WARNING
