APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:5432/YOUR_DB_NAME
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TINYFISH_API_KEY=
TINYFISH_BASE_URL=https://agent.tinyfish.ai
TINYFISH_TIMEOUT_SECONDS=180
TINYFISH_POLL_INTERVAL_SECONDS=5
TINYFISH_BATCH_SIZE=5
CORS_ORIGINS=https://app.scholr.example
SESSION_SECRET=replace-with-strong-secret
SESSION_COOKIE_NAME=scholr_session
SESSION_COOKIE_SECURE=true
AUTO_SEED=false
# IMPORTANT: Set a strong, unique password for production deployment
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
ADMIN_FULL_NAME=Platform Admin
