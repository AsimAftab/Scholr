# App runtime
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://scholr:scholr@localhost:5432/scholr

# AI provider selection
AI_PROVIDER=openai
AI_FALLBACK_ORDER=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b
CEREBRAS_MAX_COMPLETION_TOKENS=2048
GLM_API_KEY=
GLM_MODEL=glm-5
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=600
OLLAMA_KEEP_ALIVE=30m
LLM_MATCH_TOP_N=12
LLM_MATCH_RULE_WEIGHT=0.6
TINYFISH_API_KEY=
TINYFISH_BASE_URL=https://agent.tinyfish.ai
TINYFISH_TIMEOUT_SECONDS=180
TINYFISH_POLL_INTERVAL_SECONDS=5
TINYFISH_BATCH_SIZE=5

# Frontend / session
CORS_ORIGINS=http://localhost:3000
SESSION_SECRET=change-me-dev-secret
SESSION_COOKIE_NAME=scholr_session
SESSION_COOKIE_SECURE=false

# Local seed data / admin bootstrap
AUTO_SEED=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-now
ADMIN_FULL_NAME=Platform Admin
